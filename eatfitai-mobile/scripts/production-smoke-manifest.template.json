      "executeMode": "execute",
      "mutatesData": true,
      "expectedExecuteSuccess": true
    },
    {
      "key": "add-food-preview-only",
      "text": "ghi 2 trung vao bua sang",
      "expectedIntent": "ADD_FOOD",
      "expectedReviewRequired": true,
      "executeMode": "none",
      "mutatesData": false
