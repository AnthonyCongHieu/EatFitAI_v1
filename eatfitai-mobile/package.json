{
  "name": "eatfitai-mobile",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prestart": "node scripts/generate-local-ip.js",
    "predev": "node scripts/generate-local-ip.js",
    "dev": "env-cmd -f .env.development node scripts/check-api-target.js && env-cmd -f .env.development expo start",
    "dev:cloud": "env-cmd -f .env.development node scripts/check-api-target.js && env-cmd -f .env.development expo start",
    "dev:emulator": "env-cmd -f .env.development node scripts/check-api-target.js && env-cmd -f .env.development expo start",
    "dev:local": "node scripts/generate-local-ip.js && env-cmd -f .env.development.local node scripts/check-api-target.js && env-cmd -f .env.development.local expo start",
    "dev:device": "node scripts/generate-local-ip.js && env-cmd -f .env.development.local node scripts/check-api-target.js && env-cmd -f .env.development.local expo start --host lan",
    "start": "env-cmd -f .env node scripts/check-api-target.js && env-cmd -f .env expo start",
    "api:health": "env-cmd -f .env.development node scripts/check-api-target.js",
    "android": "expo run:android",
    "build:android:preview": "powershell -ExecutionPolicy Bypass -File scripts/build-android-preview.ps1",
    "install:android:preview": "powershell -ExecutionPolicy Bypass -File scripts/install-android-preview.ps1",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "guard:no-direct-ai-provider": "node scripts/check-no-direct-ai-provider.js",
    "lint": "npm run guard:no-direct-ai-provider && eslint . --ext .ts,.tsx --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "prepare": "husky install",
    "typegen": "node scripts/generate-types.js",
    "test": "jest --runInBand",
    "appium:smoke": "npm --prefix ../tools/appium run sanity:android",
    "appium:edge:android": "npm --prefix ../tools/appium run edge:android",
    "appium:cloud-proof:android": "npm --prefix ../tools/appium run cloud-proof:android",
    "device:scrcpy:android": "powershell -ExecutionPolicy Bypass -File scripts/open-scrcpy-miui.ps1",
    "maestro:smoke:android": "node scripts/run-maestro.js smoke",
    "maestro:regression:android": "node scripts/run-maestro.js regression",
    "maestro:hero:android": "node scripts/run-maestro.js hero",
    "maestro:auth-full:android": "node scripts/run-maestro.js auth-full",
    "maestro:onboarding:android": "node scripts/run-maestro.js onboarding",
    "maestro:manual-diary:android": "node scripts/run-maestro.js manual-diary",
    "maestro:ai-scan-save:android": "node scripts/run-maestro.js ai-scan-save",
    "maestro:nutrition:android": "node scripts/run-maestro.js nutrition",
    "maestro:voice-text:android": "node scripts/run-maestro.js voice-text",
    "maestro:profile-stats:android": "node scripts/run-maestro.js profile-stats",
    "maestro:miui-auth-entry:android": "node scripts/run-maestro.js miui-auth-entry",
    "maestro:miui-auth-entry:auto:android": "powershell -ExecutionPolicy Bypass -File scripts/run-maestro-miui.ps1 -Suite miui-auth-entry",
    "maestro:studio": "maestro studio",
    "detox:build:android": "detox build --configuration android.att.release",
    "detox:smoke:android": "detox test --configuration android.att.release e2e/auth-smoke.e2e.js --take-screenshots all --record-logs all",
    "automation:doctor": "node scripts/automation-doctor.js",
    "smoke:preflight": "node scripts/production-smoke-preflight.js",
    "smoke:render:verify": "node scripts/production-smoke-render-verify.js",
    "smoke:seed:cloud": "node scripts/production-smoke-seed-cloud.js",
    "smoke:auth:e2e": "node scripts/production-smoke-auth-e2e.js",
    "smoke:forgot-reset": "node scripts/production-smoke-forgot-reset.js",
    "smoke:budget": "node scripts/production-smoke-budget.js",
    "smoke:auth:api": "node scripts/production-smoke-auth-api.js",
    "smoke:user:api": "node scripts/production-smoke-user-api.js",
    "smoke:ai:api": "node scripts/production-smoke-ai-api.js",
    "smoke:cleanup": "node scripts/production-smoke-cleanup.js",
    "smoke:backend:non-ui": "node scripts/production-smoke-backend-non-ui.js",
    "smoke:regression": "node scripts/production-smoke-regression.js",
    "smoke:metrics": "node scripts/production-smoke-metrics.js",
    "smoke:rehearsal": "node scripts/production-smoke-rehearsal.js",
    "release:gate": "node scripts/product-release-gate.js"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@expo-google-fonts/be-vietnam-pro": "^0.4.1",
    "@expo-google-fonts/inter": "^0.2.3",
    "@expo/metro-runtime": "~6.1.2",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/slider": "5.0.1",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/crashlytics": "^24.0.0",
    "@react-native-google-signin/google-signin": "^16.0.0",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/native-stack": "^6.9.12",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-query": "^5.90.11",
    "axios": "^1.15.2",
    "expo": "^54.0.0",
    "expo-auth-session": "~7.0.10",
    "expo-av": "~16.0.8",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.11",
    "expo-device": "^8.0.10",
    "expo-font": "~14.0.10",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.9",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.10",
    "expo-localization": "~17.0.8",
    "expo-notifications": "^0.32.15",
    "expo-secure-store": "~15.0.8",
    "expo-sensors": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.12",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.65.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-toast-message": "^2.3.3",
    "react-native-view-shot": "^4.0.3",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "^0.5.1",
    "victory-native": "^36.8.6",
    "zod": "^3.25.76",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@babel/core": "^7.24.6",
    "@react-native-community/eslint-config": "^3.2.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.6.1",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.14.1",
    "detox": "^20.51.0",
    "env-cmd": "^11.0.0",
    "eslint": "^8.57.0",
    "eslint-config-expo": "^10.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jest": "^27.9.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "lint-staged": "^15.2.2",
    "openapi-typescript": "^7.10.1",
    "prettier": "^3.3.2",
    "react-test-renderer": "19.1.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": "20.x"
  }
}
