{
  "cli": {
    "version": ">= 16.18.0"
  },
  "build": {
    "release-base": {
      "env": {
        "NODE_ENV": "production",
        "EXPO_PUBLIC_GOOGLE_OFFLINE_ACCESS": "true",
        "EXPO_PUBLIC_GOOGLE_FORCE_CODE_FOR_REFRESH_TOKEN": "true"
      }
    },
    "preview": {
      "extends": "release-base",
      "withoutCredentials": true,
      "distribution": "internal",
      "env": {
        "APP_ENV": "preview",
        "EXPO_PUBLIC_API_BASE_URL": "https://eatfitai-backend-dev.onrender.com",
        "EXPO_PUBLIC_MEDIA_PUBLIC_BASE_URL": "https://pub-9081bce8ff6b4db5b4403ca7adae7b80.r2.dev"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "extends": "release-base",
      "distribution": "store",
      "env": {
        "APP_ENV": "production",
        "EXPO_PUBLIC_API_BASE_URL": "https://eatfitai-backend.onrender.com",
        "EXPO_PUBLIC_MEDIA_PUBLIC_BASE_URL": "https://pub-9081bce8ff6b4db5b4403ca7adae7b80.r2.dev"
      }
    },
    "e2e-test": {
      "extends": "preview",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true
      }
    }
  }
}
