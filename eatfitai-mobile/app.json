{
  "expo": {
    "name": "EatFitAI",
    "slug": "eatfitai-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "eatfitai",
    "userInterfaceStyle": "automatic",
    "icon": "./src/assets/icon.png",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#090E1C"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.eatfitai.app",
      "infoPlist": {
        "NSCameraUsageDescription": "EatFitAI cần truy cập camera để nhận diện thực phẩm",
        "NSPhotoLibraryUsageDescription": "EatFitAI cần truy cập thư viện ảnh để chọn ảnh thực phẩm",
        "UIViewControllerBasedStatusBarAppearance": true
      }
    },
    "android": {
      "googleServicesFile": "./android/app/google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#090E1C"
      },
      "package": "com.eatfitai.app",
      "versionCode": 1,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "certificateHash": "83:FF:A6:99:53:2E:D1:05:1A:38:53:5C:7B:01:E2:1D:5F:41:C5:1F"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./src/assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "7c107e36-3e2a-4c77-8447-b0fa5713e0e0"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-localization",
      "@react-native-google-signin/google-signin",
      [
        "expo-camera",
        {
          "cameraPermission": "EatFitAI cần camera để nhận diện thực phẩm bằng AI"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "EatFitAI cần truy cập thư viện ảnh để chọn ảnh thực phẩm"
        }
      ]
    ],
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "owner": "anthonyconghieu"
  }
}
