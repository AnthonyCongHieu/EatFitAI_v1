{
  "expo": {
    "name": "EatFitAI",
    "slug": "eatfitai-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "eatfitai",
    "userInterfaceStyle": "automatic",
    "icon": "./src/assets/icon.png",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A4D3C"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.eatfitai.app",
      "infoPlist": {
        "NSCameraUsageDescription": "EatFitAI cần truy cập camera để nhận diện thực phẩm",
        "NSPhotoLibraryUsageDescription": "EatFitAI cần truy cập thư viện ảnh để chọn ảnh thực phẩm",
        "UIViewControllerBasedStatusBarAppearance": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#0A4D3C"
      },
      "package": "com.eatfitai.app",
      "versionCode": 1,
      "config": {
        "locales": [
          "vi",
          "en"
        ]
      },
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./src/assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "7c107e36-3e2a-4c77-8447-b0fa5713e0e0"
      },
      "apiHost": "192.168.1.7",
      "apiPort": "5247",
      "apiScheme": "http",
      "apiBaseUrl": "http://192.168.1.7:5247"
    },
    "plugins": [
      "expo-secure-store",
      "expo-localization",
      "@react-native-google-signin/google-signin",
      [
        "expo-camera",
        {
          "cameraPermission": "EatFitAI cần camera để nhận diện thực phẩm bằng AI"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "EatFitAI cần truy cập thư viện ảnh để chọn ảnh thực phẩm"
        }
      ]
    ],
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "owner": "anthonyconghieu"
  }
}
