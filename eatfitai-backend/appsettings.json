{
  "$schema": "../schemas/appsettings.schema.json",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": [],
  "DevAllowedOrigins": [
    "http://localhost:*",
    "http://127.0.0.1:*",
    "http://10.0.2.2:*",
    "exp://*"
  ],
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=EatFitAI;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Key": "SET_IN_USER_SECRETS",
    "PreviousKeys": "",
    "Issuer": "EatFitAI",
    "Audience": "EatFitAI",
    "ExpiryInMinutes": 1440
  },
  "HealthChecks": {
    "DatabaseTimeout": "00:00:10"
  },
  "AIProvider": {
    "VisionBaseUrl": "http://127.0.0.1:5050"
  },
  "Google": {
    "WebClientId": "SET_IN_USER_SECRETS",
    "AndroidClientId": "SET_IN_USER_SECRETS",
    "IosClientId": "SET_IN_USER_SECRETS"
  },
  "Supabase": {
    "Url": "SET_IN_USER_SECRETS",
    "ServiceRoleKey": "SET_IN_USER_SECRETS",
    "FoodImagesBucket": "food-images",
    "UserFoodBucket": "user-food"
  },
  "Brevo": {
    "BaseUrl": "https://api.brevo.com",
    "ApiKey": "SET_IN_USER_SECRETS",
    "SenderEmail": "SET_IN_USER_SECRETS",
    "SenderName": "EatFitAI"
  }
}
