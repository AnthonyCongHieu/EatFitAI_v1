# Google Gemini API Key (bắt buộc cho nutrition AI)
GEMINI_API_KEY=your_legacy_single_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_KEY_POOL_JSON=[{"projectAlias":"gemini-primary","projectId":"project-1","keyAlias":"slot-a","apiKey":"replace_me","model":"gemini-2.5-flash","enabled":true}]
GEMINI_TIMEOUT_SECONDS=30
GEMINI_SHORT_COOLDOWN_SECONDS=90

# Whisper STT - tắt trên cloud (quá nặng cho Render)
ENABLE_STT=false

# Port - Render tự set, local dùng 5050
PORT=5050
