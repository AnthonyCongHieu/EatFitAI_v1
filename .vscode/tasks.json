{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Emulator Lane",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\tools\\dev\\Start-EatFitAI-EmulatorLane.ps1"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true,
        "focus": true
      },
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "Start USB Device Lane",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\tools\\dev\\Start-EatFitAI-UsbDeviceLane.ps1"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true,
        "focus": true
      },
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "TypeScript Watch (Mobile)",
      "type": "typescript",
      "tsconfig": "eatfitai-mobile/tsconfig.json",
      "option": "watch",
      "problemMatcher": [
        "$tsc-watch"
      ],
      "group": "none"
    }
  ]
}
